    "eval": "node consensus-core/eval/run-eval.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.205",
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@slack/cli-hooks": "^1.3.3",
    "typescript": "^6.0.3"
  }
}
