# Required, set your Anthropic API key.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set for OAuth mode (node app-oauth.js).
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# --- Consensus governance (Phase 1, config-driven; no admin UI) ---
# Comma-separated channel IDs whose captured decisions become ENFORCEABLE
# ('active') immediately. Captures from any OTHER channel become 'proposed' and
# are stored/shown but never hard-alerted until an authority confirms them.
# UNSET ENTIRELY → every channel is trusted (keeps ambient capture working like
# the pre-governance demo). Set to an empty string to lock everything to
# 'proposed'.
# CONSENSUS_TRUSTED_CHANNELS=C0123ABCD,C0456EFGH
#
# Comma-separated user IDs allowed to Confirm / Reject / Mark-exception /
# Supersede a decision into (or out of) an enforceable state. UNSET or EMPTY →
# everyone is authorized (keeps the one-click demo flows working).
# CONSENSUS_AUTHORITY_USERS=U0123ABCD,U0456EFGH
